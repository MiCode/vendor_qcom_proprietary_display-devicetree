&soc {
    xiaomi_touch {
        status = "okay";
        compatible = "xiaomi-touch";
        touch,name = "xiaomi-touch";
    };
};

&qupv3_se0_spi {
	status = "ok";

	touch@0 {
		compatible = "novatek,NVT-ts-spi","focaltech,fts";
		reg = <0>; //Same as CS ID
		status = "ok";
		spi-max-frequency = <9600000>;	//4800000,9600000,15000000,19200000
		spi-cs-setup-delay-ns = <300>;
		spi-cs-hold-delay-ns = <300>;
		panel = <&dsi_panel_o19_42_02_0a_fhd_video &dsi_panel_o19_36_03_0b_fhd_video>;


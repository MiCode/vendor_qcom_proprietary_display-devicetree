&soc {
	charge_screen: charge-screen {
		panel  = <&dsi_p17_41_02_0a_amoled_dsc_vid
			&dsi_p17_35_0F_0b_amoled_dsc_vid
			&dsi_p17_41_0F_0c_amoled_dsc_vid
			&dsi_p17_dummy_amoled_dsc_vid>;
	};
};

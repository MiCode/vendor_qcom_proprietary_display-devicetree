qcom,mdss-dsi-on-command = [
	39 01 00 00 00 00 05 FF AA 55 A5 84
	15 01 00 00 00 00 02 6F A9              //LCTC
	15 01 00 00 00 00 02 F4 F3
	15 01 00 00 00 00 02 6F 10
	15 01 00 00 00 00 02 F8 02
	15 01 00 00 00 00 02 F2 15              //BIST RND shift

	39 01 00 00 00 00 03 6A 00 01           //SPR setting
	15 01 00 00 00 00 02 17 03
	15 01 00 00 00 00 02 71 00              //vdo_ram_opt
	39 01 00 00 00 00 03 81 01 19           //DPC Temperature
	39 01 00 00 00 00 05 2A 00 00 04 37     //XSA,XEA,YSA,YEA
	39 01 00 00 00 00 05 2B 00 00 09 57

	39 01 00 00 00 00 03 90 03 43           //VESA Setting
	39 01 00 00 00 00 13 91 AB A8 00 08 C2 00 02 0E 00 BB 00 07 0D B7 0C B7 10 F0

	15 01 00 00 00 00 02 2F 00              //DFC_MODE_SEL[2:0]=0,FCON[2:0]=0
	15 01 00 00 00 00 02 26 00
	15 01 00 00 00 00 02 53 20              //BCTRL

	39 01 00 00 00 00 0D 3B 00 1C 00 8C 00 1C 03 CC 00 1C 0A 8C    //porch
	15 01 00 00 00 00 02 6F 10
	39 01 00 00 00 00 05 3B 00 1C 00 8C

	15 01 00 00 00 00 02 35 00              //TE on

	//39 01 00 00 00 00 03 51 0A A7           //DBV Nor1:800nit
	15 01 00 00 00 00 02 6F 04              //DBV_IDLE
	39 01 00 00 00 00 03 51 0F FF
	15 01 00 00 00 00 02 A2 02              //RP_Frame_Count=1
	15 01 00 00 00 00 02 88 01

	39 01 00 00 00 00 06 F0 55 AA 52 08 00  //Error flag ESD
	15 01 00 00 00 00 02 6F 11
	39 01 00 00 00 00 05 BE 47 00 46 00
	15 01 00 00 00 00 02 6F 05
	15 01 00 00 00 00 02 BE 9D

	39 01 00 00 00 00 06 F0 55 AA 52 08 08  //LCTC
	15 01 00 00 00 00 02 6F 0C
	39 01 00 00 00 00 09 BF 09 10 19 29 2A 3A 40 40
	15 01 00 00 00 00 02 6F 14
	39 01 00 00 00 00 09 BF 04 08 0D 0E 12 15 1C 20
	15 01 00 00 00 00 02 6F 1C
	39 01 00 00 00 00 09 BF 1D 1A 82 8D 83 80 00 00
	15 01 00 00 00 00 02 6F 24
	39 01 00 00 00 00 09 BF 30 0F 85 A5 8A 82 00 00

	39 01 00 00 00 00 06 F0 55 AA 52 08 00  //modify aod
	15 01 00 00 00 00 02 6F 68
	39 01 00 00 00 00 09 B4 00 10 00 10 00 10 00 10
	39 01 00 00 00 00 06 F0 55 AA 52 08 01
	15 01 00 00 00 00 02 6F 01
	39 01 00 00 00 00 0A E7 20 0C 10 14 00 00 00 00 00

	39 01 00 00 00 00 06 F0 55 AA 52 08 00  //modify fod enter aod flash
	15 01 00 00 00 00 02 6F 03
	15 01 00 00 00 00 02 B5 C6
	15 01 00 00 00 00 02 6F 00
	15 01 00 00 00 00 02 B2 91
	39 01 00 00 00 00 06 F0 55 AA 52 08 01
	15 01 00 00 00 00 02 6F 02
	39 01 00 00 00 00 03 D2 00 00

	05 01 00 00 78 00 01 11
	05 01 00 00 05 00 01 29];
qcom,mdss-dsi-off-command = [
	05 01 00 00 05 00 01 28
	05 01 00 00 64 00 01 10];
qcom,mdss-dsi-on-command-state = "dsi_lp_mode";
qcom,mdss-dsi-off-command-state = "dsi_lp_mode";

